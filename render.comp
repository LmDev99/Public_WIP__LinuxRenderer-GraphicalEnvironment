vec4 rayMarch(vec2 pixelCoordinate, vec3 rayOrigin, vec3 rayDirection,float startingDistance,int sampleID) {
    
    float distanceTravelled = startingDistance*0.999;
    float maxDistance = 1000.0;
    float epsilon = 0.001;
    vec3 currentPosition;

    int primaryHitClosestObjectIndex = -1;
    int primaryHitClosestObjectType = -1;
    vec3 primaryHitClosestObjectPosition;

    float lastDistance[10];
    bool skipObject[10];
    for(int i =0 ; i < 10; i++){
        skipObject[i] = false;
    }

    int rayMarchIterationLimit = 256;
    if(sampleID < 2){
        rayMarchIterationLimit = 1256;
    }

    //find where the primary ray hits
    int i = 0;
    for (i; i < rayMarchIterationLimit; ++i) {
        currentPosition = rayOrigin + rayDirection * distanceTravelled;

        float minimumDistanceFromScene = 9999;
        int currentClosestObjectIndex = -1;
        int currentObjectType = -1;
        vec3 currentObjectPosition;
        int j = 0;
        
        for(j; j < rendererPushConstants.totalNumberOfObjects; j++){
            if(skipObject[j] == false){
                currentObjectType = floatBitsToInt(sharedMemoryCache[j].memoryStore[0]); //0;
                currentObjectPosition = vec3(sharedMemoryCache[j].memoryStore[2], sharedMemoryCache[j].memoryStore[3], sharedMemoryCache[j].memoryStore[4]); //positions[j];
                
                float minimumDistanceFromObject = sceneObjectSDF(currentObjectType,currentObjectPosition,currentPosition);
                if((i > 0) && ( minimumDistanceFromObject > lastDistance[j])){
                    skipObject[j] = true;
                } 
               
                if(minimumDistanceFromObject < minimumDistanceFromScene){
                    minimumDistanceFromScene = minimumDistanceFromObject;
                    currentClosestObjectIndex = j;
                }
                
                lastDistance[j] = minimumDistanceFromObject;
            }
        }

        distanceTravelled = distanceTravelled + minimumDistanceFromScene;

        if (distanceTravelled > maxDistance || minimumDistanceFromScene < epsilon) {
			if(distanceTravelled > maxDistance){
				return vec4(0.0,0.0,0.0,distanceTravelled);
			}
            else{
                primaryHitClosestObjectIndex = currentClosestObjectIndex;
                primaryHitClosestObjectType = floatBitsToInt(sharedMemoryCache[primaryHitClosestObjectIndex].memoryStore[0]); //0;
                primaryHitClosestObjectPosition = vec3(sharedMemoryCache[primaryHitClosestObjectIndex].memoryStore[2], sharedMemoryCache[primaryHitClosestObjectIndex].memoryStore[3], sharedMemoryCache[primaryHitClosestObjectIndex].memoryStore[4]); //positions[primaryHitClosestObjectIndex];
            
            }
            
            break;
        }
    }

    if(primaryHitClosestObjectIndex == -1){
        return vec4(0.0,0.0,0.0,distanceTravelled);
    }



    //All this branch uses from above code is primaryHitClosestObjectIndex and distanceTravelled
    //the ray hit an emissive surface
    if(primaryHitClosestObjectIndex >= rendererPushConstants.numberOfNonEmissiveObjects){
        
        int emissiveMaterialIndex = floatBitsToInt(sceneData.sceneDataBlock[primaryHitClosestObjectIndex].memoryStore[1]); //this is the closest Objects material index
        vec3 lightColor = vec3(sceneData.sceneDataBlock[rendererPushConstants.materialsOffset - emissiveMaterialIndex].memoryStore[0], sceneData.sceneDataBlock[rendererPushConstants.materialsOffset - emissiveMaterialIndex].memoryStore[1], sceneData.sceneDataBlock[rendererPushConstants.materialsOffset - emissiveMaterialIndex].memoryStore[2]);
        
        return vec4(lightColor,distanceTravelled);

    }


    //All this branch uses from above code is primaryHitClosestObjectIndex and distanceTravelled
    //the ray hit a non-emissive surface
    else{
        

        vec3 normalVector = getObjectNormal(primaryHitClosestObjectType,primaryHitClosestObjectPosition,currentPosition,2);
        

        // Set material properties (example values)
        int materialIndex = floatBitsToInt(sceneData.sceneDataBlock[primaryHitClosestObjectIndex].memoryStore[1]); //this is the closest Objects material index
        

        
        vec3 albedo = vec3(sceneData.sceneDataBlock[rendererPushConstants.materialsOffset - materialIndex].memoryStore[0], sceneData.sceneDataBlock[rendererPushConstants.materialsOffset - materialIndex].memoryStore[1], sceneData.sceneDataBlock[rendererPushConstants.materialsOffset - materialIndex].memoryStore[2]);
        //return albedo;
        float metallicValue= sceneData.sceneDataBlock[rendererPushConstants.materialsOffset - materialIndex].memoryStore[4];
        float specularValue = sceneData.sceneDataBlock[rendererPushConstants.materialsOffset - materialIndex].memoryStore[5];
        //specularTint
        float roughness = sceneData.sceneDataBlock[rendererPushConstants.materialsOffset - materialIndex].memoryStore[7];
        //anistropic
        float sheen = sceneData.sceneDataBlock[rendererPushConstants.materialsOffset - materialIndex].memoryStore[9];
        float sheenTint = sceneData.sceneDataBlock[rendererPushConstants.materialsOffset - materialIndex].memoryStore[10];
        float clearCoatGloss = sceneData.sceneDataBlock[rendererPushConstants.materialsOffset - materialIndex].memoryStore[11];

        vec3 faceanduv= getCubeFaceAndUV(0, primaryHitClosestObjectPosition, currentPosition, 2);
        vec3 uvw = vec3(faceanduv.y,faceanduv.z,0.0);
        vec4 albedo1 = texture(textureArray,uvw) * 1.0;
        //return vec4(albedo1.x,albedo1.y,albedo1.z,distanceTravelled); 

        //return abs(normalVector);
        vec3 totalColor = vec3(0,0,0);
        //for(int i = 0; i < 2; i++){
        //    vec3 reflectRayOrigin;
        //    vec3 reflectRayDirection;
        //    totalColor = totalColor + reflectRay(reflectRayOrigin,reflectRayDirection);
        //}
        // Compute the light vector and view vector
        for(int i = 0; i < rendererPushConstants.numberOfEmissiveObjects; i++){
          

        
            vec3 lightPosition = vec3(sceneData.sceneDataBlock[rendererPushConstants.numberOfNonEmissiveObjects + i].memoryStore[2], sceneData.sceneDataBlock[rendererPushConstants.numberOfNonEmissiveObjects + i].memoryStore[3], sceneData.sceneDataBlock[rendererPushConstants.numberOfNonEmissiveObjects + i].memoryStore[4]);
            int emissiveObjectMaterialIndex = floatBitsToInt(sceneData.sceneDataBlock[rendererPushConstants.numberOfNonEmissiveObjects + i].memoryStore[1]);
            vec3 lightColor = vec3(sceneData.sceneDataBlock[rendererPushConstants.materialsOffset - emissiveObjectMaterialIndex].memoryStore[0],sceneData.sceneDataBlock[rendererPushConstants.materialsOffset - emissiveObjectMaterialIndex].memoryStore[1],sceneData.sceneDataBlock[rendererPushConstants.materialsOffset - emissiveObjectMaterialIndex].memoryStore[2]);

            vec3 lightVector = normalize(lightPosition - currentPosition);
            vec3 viewVector = normalize(rayOrigin - currentPosition);

            // Set material properties (example values)
            //int materialIndex = floatBitsToInt(sceneData.sceneDataBlock[primaryHitClosestObjectIndex].memoryStore[1]); //this is the closest Objects material index
            

            
            
            
            // Compute the distance to the light
            float distanceToLight = length(lightPosition - currentPosition); 

            // Perform shadow ray marching with clamped steps
            float isInLight = shadingRay(rendererPushConstants.numberOfNonEmissiveObjects + i,currentPosition + normalVector * epsilon, lightVector, distanceToLight);
            
            
            if(isInLight == 1.0){
                // Compute the color using Disney BRDF
                //vec3 currentColor = disneyBRDF(pixelCoordinate,lightColor, lightVector, viewVector, normalVector, vec3(albedo1.x,albedo1.y,albedo1.z), roughness, specularValue, metallicValue, clearCoatGloss, sheen, sheenTint,sampleID) / ((distanceToLight * distanceToLight) + getNoise(pixelCoordinate,vec2(7,6)) * 0.01);
                vec3 currentColor = disneyBRDF(pixelCoordinate,lightColor, lightVector, viewVector, normalVector, albedo, roughness, specularValue, metallicValue, clearCoatGloss, sheen, sheenTint,sampleID) / ((distanceToLight * distanceToLight) + getNoise(pixelCoordinate,vec2(7,6)) * 0.01);
                if(i==0){
                  
                    totalColor = totalColor + currentColor;
                }
                if(i==1){
                
                   
                    totalColor = totalColor + currentColor;
                }
            }
              

        }
        
        return vec4(totalColor,distanceTravelled); //+ vec3(getNoise(pixelCoordinate,vec2(9,3)),getNoise(pixelCoordinate,vec2(4,5)),getNoise(pixelCoordinate,vec2(6,1))) * 0.001;
    }
}



void main() {
    ivec2 pixelCoordinate = ivec2(gl_GlobalInvocationID.xy); // Replace with your window size
    
    if (pixelCoordinate.x >= rendererPushConstants.mainCamera.screenSize[0] || pixelCoordinate.y >= rendererPushConstants.mainCamera.screenSize[1]) {
        return;
    }  



    if(rendererPushConstants.renderStage == 0){
       


        //The shader will start by loading in all global memory (in parallel) that needs to be cached in shared memory
        //assuming 8KB of shared Memory
        
    uint numberOfGlobalMemoryAccessesPerThreadInWorkgroup = 1024 / (gl_WorkGroupSize.x * gl_WorkGroupSize.y); //expects 8 x 16 x 1 workgroup sizes
    

    uint localThreadId = gl_LocalInvocationID.x + gl_LocalInvocationID.y * gl_WorkGroupSize.x;
    
   
    //uint sceneDataBlockIndex = (localThreadId * numberOfGlobalMemoryAccessesPerThreadInWorkgroup) / numberOfGlobalMemoryAccessesPerThreadInWorkgroup;
    uint sceneDataBlockIndex = localThreadId;
   /**/

    
        
        sharedMemoryCache[sceneDataBlockIndex].memoryStore[0] = sceneData.sceneDataBlock[sceneDataBlockIndex].memoryStore[0];
        sharedMemoryCache[sceneDataBlockIndex].memoryStore[1] = sceneData.sceneDataBlock[sceneDataBlockIndex].memoryStore[1];
        sharedMemoryCache[sceneDataBlockIndex].memoryStore[2] = sceneData.sceneDataBlock[sceneDataBlockIndex].memoryStore[2];
        sharedMemoryCache[sceneDataBlockIndex].memoryStore[3] = sceneData.sceneDataBlock[sceneDataBlockIndex].memoryStore[3];
        
        sharedMemoryCache[sceneDataBlockIndex].memoryStore[4] = sceneData.sceneDataBlock[sceneDataBlockIndex].memoryStore[4];
        sharedMemoryCache[sceneDataBlockIndex].memoryStore[5] = sceneData.sceneDataBlock[sceneDataBlockIndex].memoryStore[5];
        sharedMemoryCache[sceneDataBlockIndex].memoryStore[6] = sceneData.sceneDataBlock[sceneDataBlockIndex].memoryStore[6];
        sharedMemoryCache[sceneDataBlockIndex].memoryStore[7] = sceneData.sceneDataBlock[sceneDataBlockIndex].memoryStore[7];
    
    
        sharedMemoryCache[sceneDataBlockIndex].memoryStore[8] = sceneData.sceneDataBlock[sceneDataBlockIndex].memoryStore[8];
        sharedMemoryCache[sceneDataBlockIndex].memoryStore[9] = sceneData.sceneDataBlock[sceneDataBlockIndex].memoryStore[9];
        sharedMemoryCache[sceneDataBlockIndex].memoryStore[10] = sceneData.sceneDataBlock[sceneDataBlockIndex].memoryStore[10];
        sharedMemoryCache[sceneDataBlockIndex].memoryStore[11] = sceneData.sceneDataBlock[sceneDataBlockIndex].memoryStore[11];
        
        sharedMemoryCache[sceneDataBlockIndex].memoryStore[12] = sceneData.sceneDataBlock[sceneDataBlockIndex].memoryStore[12];
        sharedMemoryCache[sceneDataBlockIndex].memoryStore[13] = sceneData.sceneDataBlock[sceneDataBlockIndex].memoryStore[13];
        sharedMemoryCache[sceneDataBlockIndex].memoryStore[14] = sceneData.sceneDataBlock[sceneDataBlockIndex].memoryStore[14];
        sharedMemoryCache[sceneDataBlockIndex].memoryStore[15] = sceneData.sceneDataBlock[sceneDataBlockIndex].memoryStore[15];
    


        barrier();

        
        float debugValue = 0;
        for(int i =0; i <128; i++){
            debugValue = debugValue + sharedMemoryCache[i].memoryStore[0];
            debugValue = debugValue + sharedMemoryCache[i].memoryStore[1];
            debugValue = debugValue + sharedMemoryCache[i].memoryStore[2];
            debugValue = debugValue + sharedMemoryCache[i].memoryStore[3];
            debugValue = debugValue + sharedMemoryCache[i].memoryStore[4];
            debugValue = debugValue + sharedMemoryCache[i].memoryStore[5];
            debugValue = debugValue + sharedMemoryCache[i].memoryStore[6];
            debugValue = debugValue + sharedMemoryCache[i].memoryStore[7];
            debugValue = debugValue + sharedMemoryCache[i].memoryStore[8];
            debugValue = debugValue + sharedMemoryCache[i].memoryStore[9];
            debugValue = debugValue + sharedMemoryCache[i].memoryStore[13];
            
        }
        if(debugValue > 444){
            imageStore(renderImageArray, ivec3(950,3,0), vec4(1.0,0.0,1.0,1.0));
        }
        if(sharedMemoryCache[1].memoryStore[3] == -3){
            imageStore(renderImageArray, ivec3(750,3,0), vec4(1.0,1.0,1.0,1.0));

        }
        

      

        
       



        // Define the sample offsets for 8x MSAA
        vec2 sampleOffsets[8] = vec2[](
            vec2(-0.25, 0.25) + vec2(getNoise(pixelCoordinate,vec2(24,99)),getNoise(pixelCoordinate,vec2(25,-64))) * 0.01,   // Top left
            vec2( 0.25, -0.25) + vec2(getNoise(pixelCoordinate,vec2(997,442)),getNoise(pixelCoordinate,vec2(43,-222))) * 0.01 ,   // Bottom right
            vec2(-0.375, -0.125) + vec2(getNoise(pixelCoordinate,vec2(9763,1256)),getNoise(pixelCoordinate,vec2(3,8))) * 0.01, // (original index 0)
            vec2( 0.125, -0.375) + vec2(getNoise(pixelCoordinate,vec2(-3,-43)),getNoise(pixelCoordinate,vec2(48,1999))) * 0.01, // (original index 1)
            vec2( 0.375,  0.125) + vec2(getNoise(pixelCoordinate,vec2(72,-1694)),getNoise(pixelCoordinate,vec2(1,22))) * 0.01, // (original index 2)
            vec2(-0.125,  0.375) + vec2(getNoise(pixelCoordinate,vec2(475,626)),getNoise(pixelCoordinate,vec2(652,867))) * 0.01, // (original index 3)
            vec2(-0.25, -0.25) + vec2(getNoise(pixelCoordinate,vec2(5309,923)),getNoise(pixelCoordinate,vec2(444,9035))) * 0.01,   // (original index 4)
            vec2( 0.25,  0.25) + vec2(getNoise(pixelCoordinate,vec2(12,-13)),getNoise(pixelCoordinate,vec2(-424,808))) * 0.01    // (original index 6)
        );

        float firstTwoSampleDistances[2];
        float startingDistanceOptimization = 0.0;

        // Get the subsample offset for the current sampleID


        for(int sampleID = 0; sampleID < 8; sampleID++){
            vec2 sampleOffset = sampleOffsets[sampleID];

            // Adjust the pixelCoordinate by the sample offset
            vec2 uv = (vec2(pixelCoordinate) + sampleOffset + 0.5) / vec2(rendererPushConstants.mainCamera.screenSize[0], rendererPushConstants.mainCamera.screenSize[1]);

            
            
            uv = uv * 2.0 - 1.0;
            uv.x *= rendererPushConstants.mainCamera.screenSize[0] / rendererPushConstants.mainCamera.screenSize[1]; // Replace with your window aspect ratio
        
            
            float fov = 60.0;
            float focalLength = 1.0 / tan(radians(fov) / 2.0);

        

            
            


            // Calculate ray origin and direction
            vec3 rayOrigin = vec3(rendererPushConstants.mainCamera.cameraPosition[0],rendererPushConstants.mainCamera.cameraPosition[1],rendererPushConstants.mainCamera.cameraPosition[2]);
            vec3 rayDirection = normalize(vec3(uv.x, focalLength, -uv.y));
            rayDirection = mat3(vec3(rendererPushConstants.mainCamera.cameraRight[0],rendererPushConstants.mainCamera.cameraRight[1],rendererPushConstants.mainCamera.cameraRight[2]), vec3(rendererPushConstants.mainCamera.cameraForward[0],rendererPushConstants.mainCamera.cameraForward[1],rendererPushConstants.mainCamera.cameraForward[2]), vec3(rendererPushConstants.mainCamera.cameraUp[0],rendererPushConstants.mainCamera.cameraUp[1],rendererPushConstants.mainCamera.cameraUp[2])) * rayDirection;


            // Perform ray marching
            vec4 rayMarchResult;
            vec3 primaryRayColor;
            if(sampleID < 2){
                rayMarchResult = rayMarch(pixelCoordinate,rayOrigin, rayDirection,0.0,sampleID);
                firstTwoSampleDistances[sampleID] = rayMarchResult.w;
                primaryRayColor = vec3(rayMarchResult.x,rayMarchResult.y,rayMarchResult.z);
                if(sampleID == 1){
                    startingDistanceOptimization = min(firstTwoSampleDistances[0],firstTwoSampleDistances[1]) * 0.999;
                    if(startingDistanceOptimization == 1000.0){
                        break;
                    }
                }

            }
            else{
                rayMarchResult = rayMarch(pixelCoordinate,rayOrigin, rayDirection,startingDistanceOptimization,sampleID);
                primaryRayColor = vec3(rayMarchResult.x,rayMarchResult.y,rayMarchResult.z);

            }

            // Perform ray marching
            //vec3 primaryRayColor = rayMarch(pixelCoordinate,rayOrigin, rayDirection);
            //vec3 primaryRayColor = vec3(1.0,0.0,1.0);

            
        
            //vec3 toneMapped = primaryRayColor / (primaryRayColor + vec3(1.0));
            //vec3 gammaCorrected = pow(toneMapped, vec3(1.0/2.2));


            //determine color based on hit
            vec4 outputColor = vec4(primaryRayColor,1.0);
            //vec4 outputColor = vec4(toneMapped,1.0);
            //vec4 outputColor = vec4(gammaCorrected,1.0);
        
            
            imageStore(renderImageArray, ivec3(pixelCoordinate,sampleID), outputColor);
        }
    }


    else if(rendererPushConstants.renderStage == 1){
        vec4 outputColor = vec4(0.0, 0.0, 0.0, 0.0);
        for(int i = 0; i < 8; i++){
            int count = 0;
            vec4 left = vec4(0.0, 0.0, 0.0, 0.0); if(pixelCoordinate.x > 0){left = imageLoad(renderImageArray,ivec3(pixelCoordinate.x-1,pixelCoordinate.y,i)); count = count + 1;}
            vec4 right = vec4(0.0, 0.0, 0.0, 0.0); if(pixelCoordinate.x < (rendererPushConstants.mainCamera.screenSize[0] - 1)){right = imageLoad(renderImageArray,ivec3(pixelCoordinate.x+1,pixelCoordinate.y,i)); count = count + 1;}
            vec4 top = vec4(0.0, 0.0, 0.0, 0.0); if(pixelCoordinate.y > 0){top = imageLoad(renderImageArray,ivec3(pixelCoordinate.x,pixelCoordinate.y-1,i)); count = count + 1;}
            vec4 bottom = vec4(0.0, 0.0, 0.0, 0.0); if(pixelCoordinate.y < (rendererPushConstants.mainCamera.screenSize[1] - 1)){bottom = imageLoad(renderImageArray,ivec3(pixelCoordinate.x,pixelCoordinate.y+1,i)); count = count + 1;}
            float neighborWeight = 0.05;
            float centerWeight   = 1.0 - neighborWeight * float(count);
            outputColor = outputColor + (centerWeight * imageLoad(renderImageArray, ivec3(pixelCoordinate,i))) + ((left + right + top + bottom) * neighborWeight);
            

        }

       
        
        

        outputColor = outputColor / 8;
        vec3 toneMapped = vec3(outputColor) / (vec3(outputColor) + vec3(1.0));
        imageStore(renderImageArray, ivec3(pixelCoordinate,0), vec4(toneMapped,outputColor.w));
        

    }
}
