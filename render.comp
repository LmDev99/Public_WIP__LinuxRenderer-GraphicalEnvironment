// Noise function
float getNoise(vec2 fragCoord, vec2 seed) {
    return fract(sin(dot(fragCoord + seed, vec2(12.9898, 78.233))) * 43758.5453);
}


// Returns true if hit.
// Outputs tEnter/tExit (t range on ray) and hitNormal at entry (approx robust).
vec3 rayIntersectBoxAABB(vec3 ro, vec3 rd, vec3 objectOrigin, vec3 halfExtents, out float tEnter, out float tExit, out vec3 hitNormal){
    vec3 boxMin = objectOrigin - halfExtents;
    vec3 boxMax = objectOrigin + halfExtents;

    // If you want to avoid INF when rd component is 0, clamp invDir.
    vec3 invDir = 1.0 / rd;

    vec3 t0 = (boxMin - ro) * invDir;
    vec3 t1 = (boxMax - ro) * invDir;

    vec3 tmin3 = min(t0, t1);
    vec3 tmax3 = max(t0, t1);

    tEnter = max(tmin3.x, max(tmin3.y, tmin3.z));
    tExit  = min(tmax3.x, min(tmax3.y, tmax3.z));
    if((tExit < 0.0) || (tEnter > tExit)){
        return vec3(0.0, 0.0, 0.0);
    }

    return vec3(1.0,tEnter,tExit);
}

