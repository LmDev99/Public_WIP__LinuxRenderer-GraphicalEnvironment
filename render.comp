// SDF for an axis-aligned cube centered at the origin with side length 'size'
float cubeSDF(vec3 objectOrigin, vec3 p, float size) {
    vec3 d = abs(p-objectOrigin) - vec3(size / 2.0);
    //float result = min(max(d.x, max(d.y, d.z)), 0.0) + length(max(d, 0.0));
    //return result + getNoise(vec2(p.x,p.z),vec2(objectOrigin.x,objectOrigin.y)) * 0.0002;
    return min(max(d.x, max(d.y, d.z)), 0.0) + length(max(d, 0.0));
}

float sphereSDF(vec3 objectOrigin, vec3 p, float radius){
     return length(p - objectOrigin) - radius;

}

vec3 getCubeFaceAndUV(int objectType, vec3 objectOrigin, vec3 p, float size) {
    // Translate the hit point to the cube's local coordinate system
    vec3 localHitPoint = p - objectOrigin;

    // Scale by the cube size to normalize
    //vec3 scaledHitPoint = localHitPoint / size;
    vec3 scaledHitPoint = (p - objectOrigin) * (2.0 / size);

    // Determine the dominant axis (largest absolute value)
    vec3 absPoint = abs(scaledHitPoint);
    float faceIndex = -1.0; // Initialize with an invalid index
    vec2 uv;

    if (absPoint.x >= absPoint.y && absPoint.x >= absPoint.z) {
        // X face
        if (scaledHitPoint.x > 0.0) {
            faceIndex = 0.0; // Positive X
        } else {
            faceIndex = 1.0; // Negative X
        }
        uv = vec2(scaledHitPoint.z, scaledHitPoint.y); // Use Z and Y for UV
    } else if (absPoint.y >= absPoint.x && absPoint.y >= absPoint.z) {
        // Y face
        if (scaledHitPoint.y > 0.0) {
            faceIndex = 2.0; // Positive Y
        } else {
            faceIndex = 3.0; // Negative Y
        }
        uv = vec2(scaledHitPoint.x, scaledHitPoint.z); // Use X and Z for UV
    } else {
        // Z face
        if (scaledHitPoint.z > 0.0) {
            faceIndex = 4.0; // Positive Z
        } else {
            faceIndex = 5.0; // Negative Z
        }
        uv = vec2(scaledHitPoint.x, scaledHitPoint.y); // Use X and Y for UV
    }

    // Map UV from [-1, 1] to [0, 1]
    uv = (uv + 1.0) * 0.5;

    // Return face index and UV as a vec3
    return vec3(faceIndex, uv);
}


vec3 getCubeNormal_centralDifference(int objectType,vec3 objectOrigin,vec3 p, float size){
   
    return normalize(vec3(cubeSDF(objectOrigin, p + vec3(0.0001,0.0,0.0), size) - cubeSDF(objectOrigin, p - vec3(0.0001,0.0,0.0), size),
                   cubeSDF(objectOrigin, p + vec3(0.0,0.0001,0.0), size) - cubeSDF(objectOrigin, p - vec3(0.0,0.0001,0.0), size),
                   cubeSDF(objectOrigin, p + vec3(0.0,0.0,0.0001), size) - cubeSDF(objectOrigin, p - vec3(0.0,0.0,0.0001), size))
             );
    
}


vec3 getObjectNormal(int objectType,vec3 objectOrigin,vec3 p, float size){
    float epsilon = 0.001;
    vec2 e1 = vec2(1.0, -1.0);
    vec2 e2 = vec2(1.0, -1.0) * epsilon;
    if(objectType == 0){
        ///*
        //return normalize(e1.xyy * cubeSDF(objectOrigin,p + e2.xyy, size) +
        //                e1.yyx * cubeSDF(objectOrigin,p + e2.yyx, size) +
        //                e1.yxy * cubeSDF(objectOrigin,p + e2.yxy, size) +
        //                e1.xxx * cubeSDF(objectOrigin,p + e2.xxx, size));
        //                */
        return getCubeNormal_centralDifference(objectType,objectOrigin,p,size);
    }
    else if(objectType == 1){
        return normalize(e1.xyy * sphereSDF(objectOrigin,p + e2.xyy, size) +
                        e1.yyx * sphereSDF(objectOrigin,p + e2.yyx, size) +
                        e1.yxy * sphereSDF(objectOrigin,p + e2.yxy, size) +
                        e1.xxx * sphereSDF(objectOrigin,p + e2.xxx, size));

    }
    else{
        return vec3(1.0,0.0,0.0);
    }


}



float sceneObjectSDF(int objectType,vec3 objectOrigin, vec3 currentPosition){
    

    //0 is cube primitive
    if(objectType == 0 || objectType == 1000){
        return cubeSDF(objectOrigin,currentPosition,2);

    }
    else if(objectType == 1 || objectType == 1001){
        return sphereSDF(objectOrigin,currentPosition,0.2);

    }
    
    return 9999;

}







const float PI = 3.14159265;


vec3 disneyDiffuse(vec3 albedo,float roughness,float nDotL,float nDotV,float nDotH){
    

    //compute Fd90
    float Fd90 = 0.5 + 2.0 * roughness * nDotH * nDotH;

    



    return (albedo/PI)    *      (1.0 + (Fd90 - 1.0) * pow(1.0 - nDotL,5.0))      *    (1.0 + (Fd90 - 1.0) * pow(1.0 - nDotV,5.0));
   
}



float normalDistributionFunction_GTR_gamma2(float nDotHSquared, float roughnessSquared){
    

    return roughnessSquared / (PI * pow((nDotHSquared * (roughnessSquared-1.0) + 1.0),2.0));

}

float geometryFunction_GGXSMITH_Aux(float nDotX, float roughness){
    //Remap roughness
    float adjustedRoughness = 0.5 + (roughness / 2.0);
    float adjustedRoughnessSquared = pow(adjustedRoughness,2);

   
    
    

    float numerator = (2 * nDotX);
    float denominator = nDotX + sqrt((adjustedRoughnessSquared + (1 - adjustedRoughnessSquared) * pow(nDotX,2)));
    return numerator / denominator;

    
}
float geometryFunction_GGXSMITH(float roughness, float nDotL, float nDotV){
    return geometryFunction_GGXSMITH_Aux(nDotL,roughness) * geometryFunction_GGXSMITH_Aux(nDotV,roughness);

}

vec3 specularFresnel(float specularValue,float metallicValue, vec3 albedo,float vDotH){
    vec3 F0_NonMetallic = vec3(0.08,0.08,0.08) * specularValue;
    vec3 F0 = (1.0 - metallicValue) * F0_NonMetallic  + (metallicValue) * albedo;

    
    return F0 + (1.0-F0) * pow((1.0-vDotH),5.0);

}


vec3 disneySpecular(float roughness, float roughnessSquared, float specularValue,float metallicValue, vec3 albedo,float nDotL, float nDotV,float vDotH, float nDotHSquared){
    

    return (normalDistributionFunction_GTR_gamma2(nDotHSquared,roughnessSquared) * specularFresnel(specularValue,metallicValue,albedo,vDotH) * geometryFunction_GGXSMITH(roughness,nDotL,nDotV)) / (4 * (nDotL) * (nDotV));

}

//since clearcoat roughness is fixed around 0.1 to 0.25, we precompute the normalization constant with roughness 0.25, so roughnessSquared is 0.0625, and roughnessSquared-1 is -0.9375
float normalDistributionFunction_GTR_gamma1(float nDotHSquared){
    
    

    float normalizationConstant = 0.107210;
    float denominator = (1 + ((-0.9375) * nDotHSquared));

    return normalizationConstant / denominator;

}

float geometryFunction_GGXSMITH_Clearcoat(float nDotL, float nDotV){
    
    float roughness = 0.25;
    float k = (roughness * roughness) / 2.0;

    float G_V = nDotV / (nDotV * (1.0 - k) + k);
    float G_L = nDotL / (nDotL * (1.0 - k) + k);
    return G_V * G_L;

}

float specularFresnel_ClearCoat(float vDotH){
    
    float F0 = 0.04;
    return F0 + (1.0 - F0) * pow(1.0 - vDotH,5.0);
}

float disneyClearCoat(float clearCoatGloss,float nDotL, float nDotV, float vDotH,float nDotHSquared){
    

    

    float D = normalDistributionFunction_GTR_gamma1(nDotHSquared);
    float G = geometryFunction_GGXSMITH_Clearcoat(nDotL,nDotV);
    float F = specularFresnel_ClearCoat(vDotH);

    float clearcoatBRDF = (D * F * G) / (4.0 * nDotL * nDotV + 0.001);

    return clearcoatBRDF * clearCoatGloss * 0.25;
    


}

vec3 disneySheen(vec3 albedo,vec3 halfVector, float sheen, float sheenTint, float vDotH){
   
    vec3 sheenColor = mix(vec3(1.0), albedo, sheenTint);
    return sheen * sheenColor * pow((1.0 - vDotH),5.0);

}


vec3 disneyBRDF(vec2 pixelCoordinate,vec3 lightColor,vec3 lightVector, vec3 viewVector, vec3 normalVector, vec3 albedo, float roughness, float specularValue,float metallicValue, float clearCoatGloss, float sheen, float sheenTint, int sampleID){
    
    //note that for nDotL and nDotV we clamp starting just above 0, this is because we need to avoid division by 0 in disneySpecular() perhaps there is better solution
    //but for now a simple clamp works

    int flip = (int(pixelCoordinate.x) + int(pixelCoordinate.y)) & 1; // 0 or 1

    int noiseScalarIndex =sampleID;
    if(flip == 1){
        noiseScalarIndex = 7 - sampleID; // reverse order on checkerboard pixels
    }
    

    //compute dot products
    float nDotL = dot(normalVector,lightVector) + (getNoise(pixelCoordinate+vec2(2*(1-2*(sampleID%2))*sampleID,2*(-1+2*(sampleID%2))*sampleID),vec2(0.123,0.2)+vec2(8*(-1+2*(sampleID%2))*sampleID,8*(1-2*(sampleID%2))*sampleID)) - 0.5) * (noiseScalars[noiseScalarIndex]);
    nDotL = clamp(nDotL,0.00000000000001,1.0);
    

    float nDotV = dot(normalVector,viewVector) + (getNoise(pixelCoordinate+vec2(2*(1-2*(sampleID%2))*sampleID,2*(-1+2*(sampleID%2))*sampleID),vec2(0.366,0.4)+vec2(8*(-1+2*(sampleID%2))*sampleID,8*(1-2*(sampleID%2))*sampleID)) - 0.5) * (noiseScalars[noiseScalarIndex]);
    nDotV = clamp(nDotV,0.00000000000001,1.0);
    

    //compute microfacet half-viewVector
    vec3 halfVector = normalize(lightVector+viewVector);

    float nDotH = dot(normalVector,halfVector) + (getNoise(pixelCoordinate+vec2(2*(1-2*(sampleID%2))*sampleID,2*(-1+2*(sampleID%2))*sampleID),vec2(0.435,0.6)+vec2(8*(-1+2*(sampleID%2))*sampleID,8*(1-2*(sampleID%2))*sampleID)) - 0.5) * (noiseScalars[noiseScalarIndex]);
    nDotH = clamp(nDotH,0.0,1.0);
    
    float nDotHSquared = nDotH * nDotH;


    float vDotH = dot(viewVector,halfVector) + (getNoise(pixelCoordinate+vec2(2*(1-2*(sampleID%2))*sampleID,2*(-1+2*(sampleID%2))*sampleID),vec2(0.7277,0.8)+vec2(3*(1+2*(sampleID%2))*sampleID,8*(1-2*(sampleID%2))*sampleID)) - 0.5) * (noiseScalars[noiseScalarIndex]);
    vDotH = clamp(vDotH,0.0,1.0);
    
    float roughnessSquared = roughness * roughness;
    



    //compute diffuse
   
    vec3 diffuseBRDF = disneyDiffuse(albedo,roughness,nDotL,nDotV,nDotH);
    vec3 specularBRDF = disneySpecular(roughness,roughnessSquared,specularValue,metallicValue,albedo,nDotL,nDotV,vDotH,nDotHSquared);
    float clearcoatBRDF = disneyClearCoat(clearCoatGloss,nDotL,nDotV,vDotH,nDotHSquared);
    vec3 sheenBRDF = disneySheen(albedo,halfVector,sheen,sheenTint,vDotH);

    vec3 totalBRDF = ((1 - metallicValue) * diffuseBRDF) + specularBRDF + sheenBRDF + vec3(clearcoatBRDF);
    //vec3 totalBRDF = diffuseBRDF;

    return totalBRDF * lightColor * nDotL;
    //return totalBRDF * lightColor;
}


//AKA shadow/light ray
//objectIndex is the index of the emissive object
float shadingRay(int objectIndex, vec3 rayOrigin, vec3 rayDirection,float distanceToLight){
    float distanceTraveled = 0.001;
    float maxDistance = 1000.0;

    float lastDistance[10];
    bool skipObject[10];
    for(int i =0 ; i < 10; i++){
        skipObject[i] = false;
    }
    for(int i = 0; i < 64; i++){
        if(distanceTraveled >= distanceToLight){
            break;
        }
        
        vec3 currentPosition = rayOrigin + rayDirection * distanceTraveled;
        float minimumDistanceFromScene = 9999;
        int currentClosestObjectIndex = -1;
        int currentObjectType = -1;
        vec3 currentObjectPosition;
        for(int j = 0; j < rendererPushConstants.totalNumberOfObjects; j++){
            if(skipObject[j] == false){
                currentObjectType = floatBitsToInt(sharedMemoryCache[j].memoryStore[0]);
                currentObjectPosition = vec3(sharedMemoryCache[j].memoryStore[2], sharedMemoryCache[j].memoryStore[3], sharedMemoryCache[j].memoryStore[4]);
                
                if(j == objectIndex){
                    continue; //ignore taking the sdf of the emissive object
                }
                float minimumDistanceFromObject = sceneObjectSDF(currentObjectType,currentObjectPosition,currentPosition);
                if((i > 0) && (minimumDistanceFromObject > lastDistance[j])){
                    skipObject[j] = true;
                }
                if(minimumDistanceFromObject < minimumDistanceFromScene){
                    minimumDistanceFromScene = minimumDistanceFromObject;
                    currentClosestObjectIndex = j;
                }
                lastDistance[j] = minimumDistanceFromObject;
            }
        }
    
        
        if(minimumDistanceFromScene < 0.001){
            return 0.0;
        }
        distanceTraveled = distanceTraveled + minimumDistanceFromScene;
        

    }
    return 1.0;
}




